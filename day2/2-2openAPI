import requests
import pandas as pd

# 1. 데이터를 요청할 주소 (보통 공공데이터포털에서 제공함)
url = "https://jsonplaceholder.typicode.com/posts" # 연습용 무료 API 주소

# 2. 서버에 데이터 요청하기
response = requests.get(url)

# 3. 받은 데이터를 파이썬 형식(JSON)으로 바꾸기
data = response.json()

# 4. Pandas로 예쁘게 표 만들기
df_api = pd.DataFrame(data)

print("--- API로 가져온 데이터 상위 5줄 ---")
print(df_api.head())
